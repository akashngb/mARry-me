# Copy this file to `.env` and fill in your keys. NEVER commit `.env`.

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# fal.ai — https://fal.ai/dashboard/keys
FAL_KEY=...

# Decart — powers Lucy 2.5 realtime in the web page — https://platform.decart.ai
DECART_API_KEY=...

# Optional overrides:
PORT=8787
CLAUDE_MODEL=claude-haiku-4-5-20251001
FAL_MODEL_ID=decart/lucy-2-5/realtime

# Party City cart automation (Python/Flask service, see ../server.py).
# The web page forwards balloon/piñata swaps here to drive a real cart.
PARTY_CITY_URL=http://127.0.0.1:5001/change
